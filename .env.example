# Copy this file to .env and adjust as needed. docker-compose reads .env automatically.

# --- Database ---
DB_NAME=rvms
DB_USERNAME=rvms_user
DB_PASSWORD=rvms_password

# --- JWT ---
# Generate a strong random secret for production, e.g.: openssl rand -base64 48
JWT_SECRET=change-this-super-secret-key-in-production-min-256-bits-long-please
JWT_EXPIRATION_MS=86400000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- LRU customer search cache ---
LRU_CACHE_SIZE=50
LRU_CACHE_TTL_SECONDS=600
LRU_USE_REDIS=true

# --- AI / LangChain4j ---
# Leave AI_MOCK_MODE=true to run fully offline with a deterministic mock model.
# Set to false and provide OPENAI_API_KEY for real LLM-backed responses.
AI_MOCK_MODE=true
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
